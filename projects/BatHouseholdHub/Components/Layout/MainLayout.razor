@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="app-shell">
    <aside class="sidebar"><NavMenu /></aside>
    <main class="main-area">
        <header class="topbar">
            <div><span class="eyebrow">GOTHAM'S COZIEST SAFEHOUSE</span><strong>Me + Jess</strong></div>
            <div class="topbar-right">
                <button class="theme-toggle" title="Toggle light/dark" @onclick="ToggleTheme">@ThemeIcon</button>
                <div class="avatar-pair"><span>M</span><span>J</span></div>
            </div>
        </header>
        <article class="content">@Body</article>
    </main>
</div>

<div id="blazor-error-ui">Something went sideways. <a href="" class="reload">Reload</a><a class="dismiss">×</a></div>

@code {
    string ThemeIcon = "🌙";
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var current = await JS.InvokeAsync<string>("batHouseTheme.current");
            ThemeIcon = current == "dark" ? "☀" : "🌙";
            StateHasChanged();
        }
    }
    async Task ToggleTheme()
    {
        var next = await JS.InvokeAsync<string>("batHouseTheme.toggle");
        ThemeIcon = next == "dark" ? "☀" : "🌙";
    }
}
