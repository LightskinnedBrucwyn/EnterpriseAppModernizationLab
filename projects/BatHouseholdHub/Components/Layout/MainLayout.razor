@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="app-shell @(IsHome ? "is-home" : "")">
    @if (!IsHome)
    {
        <NavMenu />
    }
    <main class="main-area">
        <article class="content @(IsHome ? "content-flush" : "")">@Body</article>
    </main>
</div>

<div id="blazor-error-ui">Something went sideways. <a href="" class="reload">Reload</a><a class="dismiss">×</a></div>

@code {
    bool IsHome => Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/') == "";
}
