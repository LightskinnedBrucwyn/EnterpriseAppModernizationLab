@page "/"
@inject ActivePersonService ActivePerson
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Manor Household Hub</PageTitle>

<div id="vanta-stage" class="vanta-stage"></div>

<section class="cloud-landing">
    <div class="cloud-greeting">
        <span class="kicker">@DateTime.Now.ToString("dddd, MMMM d")</span>
        <h1>Good @(TimeOfDay), <em>@(ActivePerson.Current)</em>.</h1>
    </div>

    <nav class="cloud-menu">
        <a class="cloud-link" href="bills"><span>💵</span>Bills &amp; Money</a>
        <a class="cloud-link" href="calendar"><span>📅</span>Calendar</a>
        <a class="cloud-link" href="shopping-tracker"><span>🛍️</span>Shopping Tracker</a>
        <a class="cloud-link" href="groceries-tracker"><span>🥬</span>Groceries Tracker</a>
        <a class="cloud-link" href="butler"><span>🦇</span>Home Butler</a>
    </nav>

    <details class="jess-surprise">
        <summary><span class="love-heart">♥</span><span class="open-hint">a tiny surprise ✦</span></summary>
        <div class="love-reveal"><img src="images/jess-love-note.png" alt="Two cozy bats cuddling beneath the moon with a love note for Jess" /><p>Built into our little home, just like you are. ♥</p></div>
    </details>
</section>

@code {
    static string TimeOfDay
    {
        get
        {
            var hour = DateTime.Now.Hour;
            if (hour < 12) return "morning";
            if (hour < 17) return "afternoon";
            return "evening";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("vantaClouds.init", "vanta-stage");
        }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("vantaClouds.dispose"); }
        catch (JSDisconnectedException) { }
    }
}
