@page "/"
@inject ActivePersonService ActivePerson

<PageTitle>Manor Household Hub</PageTitle>

<section class="page-heading">
    <div><span class="kicker">@DateTime.Now.ToString("dddd, MMMM d")</span><h1>Good @(TimeOfDay), <em>@(ActivePerson.Current)</em>.</h1><p>Pick a spot to land — everything's one tap away.</p></div>
</section>

<section class="menu-grid">
    <a class="menu-card" href="bills">
        <span class="menu-icon sage">💵</span>
        <div><h2>Bills &amp; Money</h2><p>Track spending, log income, manage bills, import from Rocket Money.</p></div>
    </a>
    <a class="menu-card" href="calendar">
        <span class="menu-icon peach">📅</span>
        <div><h2>Calendar</h2><p>See what's due and when across the month.</p></div>
    </a>
    <a class="menu-card" href="shopping-tracker">
        <span class="menu-icon butter">🛍️</span>
        <div><h2>Shopping Tracker</h2><p>Wishlist items, fave stores, and quick product search.</p></div>
    </a>
    <a class="menu-card" href="groceries-tracker">
        <span class="menu-icon lilac">🥬</span>
        <div><h2>Groceries Tracker</h2><p>Plan the week, build the list, save recipes.</p></div>
    </a>
    <a class="menu-card" href="butler">
        <span class="menu-icon green">🦇</span>
        <div><h2>Home Butler</h2><p>Ask for help finding deals, products, or info.</p></div>
    </a>
</section>

<details class="jess-surprise">
    <summary><span class="love-heart">♥</span><div><small>HEY JESS…</small><strong>You have a tiny surprise</strong></div><span class="open-hint">open me ✦</span></summary>
    <div class="love-reveal"><img src="images/jess-love-note.png" alt="Two cozy bats cuddling beneath the moon with a love note for Jess" /><p>Built into our little home, just like you are. ♥</p></div>
</details>

@code {
    static string TimeOfDay
    {
        get
        {
            var hour = DateTime.Now.Hour;
            if (hour < 12) return "morning";
            if (hour < 17) return "afternoon";
            return "evening";
        }
    }
}
