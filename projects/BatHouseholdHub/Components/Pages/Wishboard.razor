@page "/wishboard"
@inject HouseholdStore Store
@inject ProductLookupService Lookup
@inject OpenGraphScraperService Scraper
@inject HomeButlerService Butler

<PageTitle>Wishboard — Bat House</PageTitle>
<section class="page-heading"><div><span class="kicker">DREAM IT, PRICE IT, PLAN IT</span><h1>Purchase wishboard</h1><p>A calm place for things you might buy—before they become surprise spending.</p></div><button class="button primary" @onclick="OpenAddForm">＋ Save an idea</button></section>

<section class="search-window panel">
    <span class="search-icon">⌕</span><input @bind="Search" @bind:event="oninput" placeholder="Search your saved tech, shoes, clothes…" />
    <a class="button magic" target="_blank" href="@ShoppingSearchUrl">Search the web ↗</a>
</section>

<section class="capture-bar">
    <div><span class="kicker">FOUND SOMETHING?</span><strong>Capture this find</strong><small>Paste a link — we'll try to pull the name, price, and photo straight from the page automatically.</small></div>
    <input @bind="QuickUrl" @bind:event="oninput" placeholder="Paste product link here…" disabled="@IsLookingUp" />
    <button class="button primary" disabled="@(!IsWebUrl(QuickUrl) || IsLookingUp)" @onclick="CaptureLink">@(IsLookingUp ? "Looking it up…" : "Make card →")</button>
</section>

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="success-toast">✓ @StatusMessage @if (LastRemoved is not null) { <button class="undo-button" @onclick="UndoLast">Undo</button> }</div>
}
@if (!string.IsNullOrWhiteSpace(LookupNote)) { <div class="import-message error">@LookupNote</div> }

@if (ShowForm)
{
    <section class="panel form-panel">
        <div class="panel-head"><div><span class="kicker">PASTE IT HERE</span><h2>@(EditingId is null ? "Save a purchase idea" : "Edit purchase idea")</h2></div><button class="icon-button" @onclick="CloseForm">×</button></div>
        <div class="form-grid">
            <label>Item name<input @bind="Draft.Name" placeholder="Headphones, boots, laptop…" /></label>
            <label>Category<select @bind="Draft.Category"><option>Tech</option><option>Shoes</option><option>Clothes</option><option>Home</option><option>Hobby</option><option>Other</option></select></label>
            <label>For whom?<select @bind="Draft.Owner"><option>Shared</option><option>Me</option><option>Jess</option></select></label>
            <label>Estimated price<input type="number" step=".01" @bind="Draft.Price" /></label>
            <label>Already saved<input type="number" step=".01" @bind="Draft.Saved" /></label>
            <label>Priority<select @bind="Draft.Priority"><option>Need soon</option><option>Would be nice</option><option>Someday</option></select></label>
            <label class="wide">Product link<input @bind="Draft.ProductUrl" placeholder="https://store.example/item" /></label>
            <label>Image link<input @bind="Draft.ImageUrl" placeholder="https://…/photo.jpg" /></label>
            <label class="wide">Notes<textarea @bind="Draft.Notes" placeholder="Why we want it, size, color, alternatives…"></textarea></label>
        </div>
        <div class="form-actions">
            <button class="button primary" disabled="@(string.IsNullOrWhiteSpace(Draft.Name))" @onclick="SaveIdea">@(EditingId is null ? "Add to wishboard" : "Update idea")</button>
            <button class="text-button" @onclick="ClearForm">Clear</button>
        </div>
    </section>
}

<div class="wish-summary">
    <span><small>PLANNED</small><strong>@Filtered.Sum(x => x.Price).ToString("C0")</strong></span>
    <span><small>SAVED</small><strong>@Filtered.Sum(x => x.Saved).ToString("C0")</strong></span>
    <span><small>IDEAS</small><strong>@Filtered.Count()</strong></span>
</div>

@if (!Filtered.Any())
{
    <section class="empty-state"><span>✦</span><h2>No ideas here yet</h2><p>Search the web, copy a product link or image link, and save it here.</p></section>
}
else
{
    <section class="wish-grid">
    @foreach (var item in Filtered.OrderBy(x => PriorityRank(x.Priority)).ThenBy(x => x.Name))
    {
        var percent = item.Price <= 0 ? 0 : Math.Min(100, item.Saved / item.Price * 100);
        <article class="wish-card panel">
            <div class="product-image">
                @if (IsWebUrl(item.ImageUrl)) { <img src="@item.ImageUrl" alt="@item.Name" /> }
                else { <span>@CategoryIcon(item.Category)</span> }
                <b class="priority @item.Priority.Replace(" ", "-").ToLowerInvariant()">@item.Priority</b>
            </div>
            <div class="wish-body"><span class="kicker">@item.Category · @item.Owner</span><h2>@item.Name</h2><strong class="product-price">@item.Price.ToString("C")</strong>
                @if (!string.IsNullOrWhiteSpace(item.Notes)) { <p>@item.Notes</p> }
                <div class="progress"><i style="width:@percent%"></i></div><small>@item.Saved.ToString("C0") saved · @percent.ToString("0")%</small>
                @if (item.Contributions.Count > 0)
                {
                    <small class="contribution-history">@string.Join(" · ", item.Contributions.OrderByDescending(c => c.Date).Take(3).Select(c => $"+{c.Amount:C0} {c.Date:MMM d}"))</small>
                }
                <div class="contribute-row">
                    <input type="number" step=".01" min="0" @bind="ContributionAmount[item.Id]" placeholder="Add $ saved" />
                    <button class="text-button" @onclick="() => LogContribution(item)">+ Log</button>
                </div>
                <div class="card-actions">
                    @if (IsWebUrl(item.ProductUrl)) { <a class="button magic" target="_blank" href="@item.ProductUrl">View item ↗</a> }
                    <span class="row-actions"><button class="icon-button" title="Edit" @onclick="() => Edit(item)">✎</button><button class="delete-button" title="Remove" @onclick="() => Delete(item)">×</button></span>
                </div>
            </div>
        </article>
    }
    </section>
}

<aside class="api-callout"><span>⚡</span><div><strong>Smart capture, cheapest option first</strong><p>Pasting a link tries the page's own product data first (free), then <a href="butler">Home Butler</a> if it's configured, then Claude only as a last resort. <a href="butler">Check Home Butler status →</a></p></div></aside>

@code {
    string Search = "", QuickUrl = ""; bool ShowForm; PurchaseIdea Draft = new();
    Guid? EditingId;
    bool IsLookingUp;
    string LookupNote = "";
    string StatusMessage = "";
    PurchaseIdea? LastRemoved;
    int LastRemovedIndex = -1;
    SafeAmountMap ContributionAmount = new();
    class SafeAmountMap
    {
        readonly Dictionary<Guid, decimal> map = [];
        public decimal this[Guid id] { get => map.TryGetValue(id, out var v) ? v : 0; set => map[id] = value; }
    }
    IEnumerable<PurchaseIdea> Filtered => string.IsNullOrWhiteSpace(Search) ? Store.Data.PurchaseIdeas : Store.Data.PurchaseIdeas.Where(x => $"{x.Name} {x.Category} {x.Owner} {x.Notes}".Contains(Search, StringComparison.OrdinalIgnoreCase));
    string ShoppingSearchUrl => $"https://www.google.com/search?tbm=shop&q={Uri.EscapeDataString(string.IsNullOrWhiteSpace(Search) ? "shopping ideas" : Search)}";
    void OpenAddForm() { Draft = new(); EditingId = null; ShowForm = true; }
    void ClearForm() { var keepEditing = EditingId; var id = Draft.Id; Draft = new() { Id = id }; EditingId = keepEditing; }
    void CloseForm() { ShowForm = false; EditingId = null; }
    void Edit(PurchaseIdea item)
    {
        EditingId = item.Id;
        Draft = new PurchaseIdea { Id = item.Id, Name = item.Name, Category = item.Category, Owner = item.Owner, Priority = item.Priority, Price = item.Price, Saved = item.Saved, ProductUrl = item.ProductUrl, ImageUrl = item.ImageUrl, Notes = item.Notes, Contributions = item.Contributions };
        ShowForm = true;
    }
    async Task SaveIdea()
    {
        LastRemoved = null;
        Draft.ProductUrl = CleanUrl(Draft.ProductUrl);
        Draft.ImageUrl = CleanUrl(Draft.ImageUrl);
        if (EditingId is Guid id)
        {
            var existing = Store.Data.PurchaseIdeas.FirstOrDefault(x => x.Id == id);
            if (existing is not null)
            {
                existing.Name = Draft.Name; existing.Category = Draft.Category; existing.Owner = Draft.Owner;
                existing.Priority = Draft.Priority; existing.Price = Draft.Price; existing.Saved = Draft.Saved;
                existing.ProductUrl = Draft.ProductUrl; existing.ImageUrl = Draft.ImageUrl; existing.Notes = Draft.Notes;
            }
            StatusMessage = $"Updated \"{Draft.Name}\".";
        }
        else
        {
            Store.Data.PurchaseIdeas.Add(Draft);
            StatusMessage = $"Added \"{Draft.Name}\" to the wishboard.";
        }
        await Store.SaveAsync();
        Draft = new(); ShowForm = false; EditingId = null;
    }
    async Task Delete(PurchaseIdea item)
    {
        LastRemovedIndex = Store.Data.PurchaseIdeas.IndexOf(item);
        LastRemoved = item;
        Store.Data.PurchaseIdeas.Remove(item);
        await Store.SaveAsync();
        StatusMessage = $"Removed \"{item.Name}\".";
    }
    async Task UndoLast()
    {
        if (LastRemoved is not null)
        {
            Store.Data.PurchaseIdeas.Insert(Math.Min(LastRemovedIndex, Store.Data.PurchaseIdeas.Count), LastRemoved);
            LastRemoved = null;
            await Store.SaveAsync();
        }
        StatusMessage = "";
    }
    async Task LogContribution(PurchaseIdea item)
    {
        var amount = ContributionAmount[item.Id];
        if (amount <= 0) return;
        item.Saved += amount;
        item.Contributions.Add(new() { Amount = amount, Date = DateTime.Today });
        await Store.SaveAsync();
        StatusMessage = $"Logged +{amount:C} toward \"{item.Name}\".";
        ContributionAmount[item.Id] = 0;
    }
    async Task CaptureLink()
    {
        if (!IsWebUrl(QuickUrl)) return;
        LastRemoved = null;
        LookupNote = "";
        StatusMessage = "";
        var url = QuickUrl.Trim();
        var uri = new Uri(url);
        Draft = new PurchaseIdea { ProductUrl = url, Name = PrettyStoreName(uri.Host) };
        QuickUrl = "";

        IsLookingUp = true;
        try
        {
            // Free first: most storefronts embed Open Graph / JSON-LD product data directly in the page.
            var result = await Scraper.ScrapeAsync(url);
            var source = "the page itself";

            // Local LLM next (no token cost) -- only useful once Ollama/Qwen is reachable and wired up.
            if (!result.Success && Butler.IsConfigured)
            {
                result = await Butler.LookupAsync(url, pageExcerpt: url);
                source = "Home Butler";
            }

            // Paid API as a last resort, only if explicitly configured.
            if (!result.Success && Lookup.IsConfigured)
            {
                result = await Lookup.LookupAsync(url);
                source = "Claude";
            }

            if (result.Success)
            {
                if (!string.IsNullOrWhiteSpace(result.Name)) Draft.Name = result.Name;
                if (result.Price > 0) Draft.Price = result.Price;
                if (!string.IsNullOrWhiteSpace(result.ImageUrl)) Draft.ImageUrl = result.ImageUrl;
                StatusMessage = $"Pulled product details from {source}.";
            }
            else
            {
                LookupNote = $"Couldn't auto-fill details ({result.Error}) — fill them in below.";
            }
        }
        finally { IsLookingUp = false; }
        ShowForm = true;
    }
    static bool IsWebUrl(string value) => Uri.TryCreate(value, UriKind.Absolute, out var uri) && (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);
    static string CleanUrl(string value) => IsWebUrl(value) ? value.Trim() : "";
    static int PriorityRank(string value) => value switch { "Need soon" => 0, "Would be nice" => 1, _ => 2 };
    static string CategoryIcon(string value) => value switch { "Tech" => "⌘", "Shoes" => "👟", "Clothes" => "👕", "Home" => "⌂", "Hobby" => "★", _ => "✦" };
    static string PrettyStoreName(string host)
    {
        var name = host.Replace("www.", "", StringComparison.OrdinalIgnoreCase).Split('.')[0];
        return $"Find from {char.ToUpperInvariant(name[0])}{name[1..]}";
    }
}
